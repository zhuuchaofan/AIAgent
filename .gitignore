# 覆盖全局 gitignore 的 *.json 规则，允许项目 JSON 文件入库
!*.json

# .NET
bin/
obj/
*.user
*.suo
.vs/
*.csproj.user

# 敏感文件 & 凭证
serviceAccountKey.json
google-credentials.json
.env
.env.local
.env.production
appsettings.Development.json
appsettings.*.json
*.key

# macOS
.DS_Store

# 前端 (Next.js)
life-web/node_modules/
life-web/.next/
life-web/out/
life-web/.env*.local

# 日志
*.log

# 本地工具配置
.claude/settings.local.json
.vscode/launch.json
